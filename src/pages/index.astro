---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturedProject from '../components/FeaturedProject.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Expertise from '../components/Expertise.astro';
import About from '../components/About.astro';
import Writing from '../components/Writing.astro';
import TestimonialCard from '../components/TestimonialCard.astro';

const personJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Davor Minchorov",
    "url": "https://davorminchorov.com",
    "jobTitle": "Software Engineer",
    "description": "Software engineer partnering with startups and enterprises to design and build custom software solutions.",
    "knowsAbout": ["Software Engineering", "System Design", "Full-Stack Development", "Software Architecture"],
    "sameAs": [
      "https://x.com/davorminchorov",
      "https://bsky.app/profile/davorminchorov.com",
      "https://linkedin.com/in/davorminchorov",
      "https://github.com/davorminchorov"
    ]
  }
});
---

<BaseLayout>
  <script type="application/ld+json" set:html={personJsonLd} />
  <Hero />

  <About />
  <Expertise />

  <!-- Projects -->
  <section id="projects" class="py-[88px]">
    <div class="max-w-[1080px] mx-auto px-7">
      <span class="section-label animate">Projects & Client Work</span>
      <h2 class="section-title animate delay-1">What I've Built</h2>

      <FeaturedProject />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-5">
        <ProjectCard
          icon="🏛️"
          title="Non-Profit Fundraising Platform"
          description="Designed and built a full-suite fundraising, CRM, and marketing platform for a US-based non-profit, enabling organizations to manage donors, run campaigns, and track engagement at scale."
          colorScheme="warm"
          animationDelay="delay-3"
        />
<ProjectCard
          icon="🎰"
          title="iGaming Platform with Blockchain"
          description="Built internal packages and integrated blockchain/Web3 services for an iGaming platform, working with Symfony to deliver new features and third-party integrations."
          colorScheme="blue"
          animationDelay="delay-6"
        />
        <ProjectCard
          icon="🏥"
          title="Healthcare Web Application"
          description="Developed and optimized REST API endpoints for a medical web application, improving existing code performance and writing comprehensive feature tests."
          colorScheme="warm"
          animationDelay="delay-7"
        />
        <ProjectCard
          icon="💬"
          title="Community Social Network"
          description="Built REST API and GraphQL features for a community social network, including third-party integrations, UI components, and test-driven development with full-stack Laravel and Vue.js."
          colorScheme="purple"
          animationDelay="delay-8"
        />
        <ProjectCard
          icon="🎬"
          title="Enterprise Entertainment Platform"
          description="Worked on a high-traffic, data-intensive enterprise entertainment platform serving millions of users daily — optimizing performance with Elasticsearch, Redis, and caching layers while reviewing code."
          colorScheme="blue"
          animationDelay="delay-9"
        />
        <ProjectCard
          icon="💰"
          title="Enterprise Financial Application"
          description="Led a team of developers and QA engineers on a US-based financial application, driving architectural proposals, code reviews, and REST API development."
          colorScheme="warm"
          animationDelay="delay-10"
        />
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="testimonials" class="py-[88px]">
    <div class="max-w-[1080px] mx-auto px-7">
      <span class="section-label animate">Testimonials</span>
      <h2 class="section-title animate delay-1">What My Clients Say</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-5">
        <TestimonialCard
          quote="Davor consistently proved to be one of the most engaged and forward-thinking engineers on the team. He didn't just deliver features — he actively shaped the direction of the product. His understanding of modern development practices, design patterns, and emerging tools was always up to date, and he used that knowledge to elevate the entire codebase."
          name="Bartosz P."
          role="Staff Backend Engineer"
          industry="iGaming"
          colorScheme="blue"
          animationDelay="delay-2"
        />
        <TestimonialCard
          quote="Davor consistently delivers game-changing features that drive real customer and business impact. He's built foundational capabilities that transformed how our customers manage donor relationships and organizational data. His systematic approach to complex technical challenges ensures customers can successfully scale their operations. Davor's reliable execution on high-impact projects makes him essential to our team's success."
          name="Kevin R."
          role="Product Manager"
          industry="Non-Profit / Fundraising"
          colorScheme="warm"
          animationDelay="delay-3"
        />
      </div>
    </div>
  </section>

  <Writing />
</BaseLayout>
