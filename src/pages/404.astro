---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — Davor Minchorov" description="The page you're looking for doesn't exist or has been moved.">
  <section class="pt-[148px] pb-[88px] border-b border-border">
    <div class="max-w-[1080px] mx-auto px-7 text-center">
      <div class="font-mono text-xs text-accent uppercase tracking-wider font-medium mb-5 animate">
        Error 404
      </div>
      <h1 class="font-display text-[clamp(36px,5vw,58px)] leading-[1.12] tracking-tight text-text mb-6 font-bold animate delay-1">
        Page not found
      </h1>
      <p class="text-[17px] text-text-secondary max-w-[480px] mx-auto leading-relaxed animate delay-2">
        The page you're looking for doesn't exist or has been moved. Let's get you back on track.
      </p>
      <div class="mt-10 animate delay-3">
        <a href="/" class="arrow-link text-base">
          Back to homepage <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
