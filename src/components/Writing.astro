---
---

<section id="writing" class="py-[88px] border-t border-border">
  <div class="max-w-[1080px] mx-auto px-7">
    <div class="section-label animate">Writing & Knowledge</div>
    <div class="section-title animate delay-1">Thinking Out Loud</div>
    <p class="section-desc animate delay-2" id="writing-desc">
      Articles on software development, architecture, and the craft of building things that last.
    </p>

    <div id="writing-posts" class="flex flex-col mt-9"></div>

    <a href="https://codyssey.dev" class="arrow-link mt-7 animate delay-6" target="_blank">
      More on Codyssey.dev
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 9L9 5M9 5H5.5M9 5v3.5"/></svg>
    </a>
  </div>
</section>

<script>
  async function loadInsights() {
    const container = document.getElementById('writing-posts');
    const desc = document.getElementById('writing-desc');
    if (!container || !desc) return;

    try {
      const res = await fetch('https://core.codyssey.dev/api/author-profiles/davor-minchorov');
      const data = await res.json();

      const insights = (data.data?.author_insights || [])
        .filter((i: any) => i.published)
        .sort((a: any, b: any) => new Date(b.publish_date).getTime() - new Date(a.publish_date).getTime())
        .slice(0, 3);

      if (insights.length === 0) {
        desc.textContent += ' New content coming soon to Codyssey.dev.';
        return;
      }

      insights.forEach((insight: any, i: number) => {
        const date = new Date(insight.publish_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
        const link = document.createElement('a');
        link.href = `https://codyssey.dev/insights/${insight.slug}`;
        link.target = '_blank';
        link.className = `flex items-baseline justify-between gap-6 py-5 border-b border-border no-underline transition-all duration-200 hover:pl-2.5 group ${i === 0 ? 'border-t' : ''} animate delay-${i + 3}`;
        link.innerHTML = `
          <h4 class="text-base font-medium text-text tracking-tight group-hover:text-accent transition-colors">
            ${insight.title}
          </h4>
          <span class="font-mono text-[11px] text-text-dim whitespace-nowrap">
            ${date}
          </span>
        `;
        container.appendChild(link);
      });
    } catch {
      desc.textContent += ' New content coming soon to Codyssey.dev.';
    }
  }

  loadInsights();
</script>
