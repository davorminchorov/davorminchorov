---
import FeaturedProject from './FeaturedProject.astro';
import ProjectCard from './ProjectCard.astro';
---

<section id="projects" class="py-[88px]">
  <div class="max-w-[1080px] mx-auto px-7">
    <span class="section-label animate">Projects & Client Work</span>
    <h2 class="section-title animate delay-1">What I've Built</h2>

    <FeaturedProject />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-5">
      <ProjectCard
        title="Non-Profit Fundraising Platform"
        description="Designed and built a fundraising, CRM, and marketing platform for a US non-profit."
        colorScheme="warm"
        animationDelay="delay-3"
      />
      <ProjectCard
        title="iGaming Platform with Blockchain"
        description="Built internal packages and integrated blockchain and Web3 services for crypto payments on an iGaming platform."
        colorScheme="blue"
        animationDelay="delay-6"
      />
      <ProjectCard
        title="Healthcare Web Application"
        description="Backend work on a medical app handling patient records and clinical workflows."
        colorScheme="warm"
        animationDelay="delay-7"
      />
      <ProjectCard
        title="Community Social Network"
        description="Built real-time feeds, third-party integrations, and UI components for a community social network."
        colorScheme="purple"
        animationDelay="delay-8"
      />
      <ProjectCard
        title="Enterprise Entertainment Platform"
        description="Search performance and caching work on a high-traffic platform serving millions of daily users."
        colorScheme="blue"
        animationDelay="delay-9"
      />
      <ProjectCard
        title="Enterprise Financial Application"
        description="Led developers and QA on a US financial application — system architecture and feature delivery under regulatory requirements."
        colorScheme="warm"
        animationDelay="delay-10"
      />
    </div>
  </div>
</section>
