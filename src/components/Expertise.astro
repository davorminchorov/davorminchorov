---
const items = [
  {
    num: '01',
    title: 'System Design & Architecture',
    desc: 'Designing systems that hold up as teams and requirements change.',
  },
  {
    num: '02',
    title: 'Full-Stack Development',
    desc: 'APIs, backend services, and the UI on top of them.',
  },
  {
    num: '03',
    title: 'Process & Team Enablement',
    desc: 'Custom internal tooling and engineering practices that unblock teams.',
  },
  {
    num: '04',
    title: 'Mentoring',
    desc: 'Code reviews, pairing, and direct feedback for engineers leveling up.',
  },
];
---

<section id="expertise" class="py-[88px] border-t border-border">
  <div class="max-w-[1080px] mx-auto px-7">
    <span class="section-label animate">Expertise</span>
    <h2 class="section-title animate delay-1">What I Bring to the Table</h2>
    <p class="section-desc animate delay-2">
      A decade across startups and Fortune 500s.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mt-9">
      {items.map((item, i) => (
        <div class={`p-8 border border-border rounded-[10px] bg-bg-card shadow-sm animate delay-${i + 3}`}>
          <div class="font-display text-[26px] font-bold text-accent mb-3.5 leading-none">{item.num}</div>
          <h3 class="text-[15px] font-semibold mb-2 tracking-tight">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
