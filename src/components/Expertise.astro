---
const items = [
  {
    num: '01',
    title: 'System Design & Architecture',
    desc: 'Designing scalable, maintainable systems that evolve gracefully with business requirements and team growth.',
  },
  {
    num: '02',
    title: 'Full-Stack Development',
    desc: 'Building end-to-end solutions with modern stacks, from robust APIs and backend services to polished user interfaces.',
  },
  {
    num: '03',
    title: 'Process & Team Enablement',
    desc: 'Improving business processes through custom software, better tooling, and engineering practices that help teams move faster.',
  },
];
---

<section id="expertise" class="py-[88px] border-t border-border">
  <div class="max-w-[1080px] mx-auto px-7">
    <div class="section-label animate">Expertise</div>
    <div class="section-title animate delay-1">What I Bring to the Table</div>
    <p class="section-desc animate delay-2">
      A decade of building software across industries, from early-stage startups to BigTech Fortune 500 companies.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-9">
      {items.map((item, i) => (
        <div class={`p-8 border border-border rounded-[10px] bg-bg-card shadow-sm animate delay-${i + 3}`}>
          <div class="font-display text-[26px] font-bold text-accent mb-3.5 leading-none">{item.num}</div>
          <h4 class="text-[15px] font-semibold mb-2 tracking-tight">{item.title}</h4>
          <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
