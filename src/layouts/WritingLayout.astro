---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": frontmatter.title,
  "description": frontmatter.description,
  "datePublished": frontmatter.date,
  "author": {
    "@type": "Person",
    "name": "Davor Minchorov",
    "url": "https://davorminchorov.com"
  }
});
---

<BaseLayout title={`${frontmatter.title} — Davor Minchorov`} description={frontmatter.description}>
  <script type="application/ld+json" set:html={articleJsonLd} />
  <article class="pt-[140px] pb-[88px]">
    <div class="max-w-[680px] mx-auto px-7">
      <!-- Header -->
      <header class="mb-12 pb-8 border-b border-border">
        <a href="/#writing" class="arrow-link mb-6 rotate-180-icon">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" class="rotate-180"><path d="M5 9L9 5M9 5H5.5M9 5v3.5"/></svg>
          Back to all posts
        </a>
        <h1 class="font-display text-[clamp(28px,4vw,42px)] leading-[1.15] tracking-tight font-bold mt-6 mb-4">
          {frontmatter.title}
        </h1>
        <div class="flex items-center gap-4 flex-wrap">
          <time class="font-mono text-[12px] text-text-muted tracking-wide">{formattedDate}</time>
          {frontmatter.tags && (
            <div class="flex gap-2">
              {frontmatter.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      <!-- Content -->
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  /* Prose styling for article content */
  .prose :global(h2) {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 24px;
    font-weight: 700;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    letter-spacing: -0.015em;
  }
  .prose :global(h3) {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 20px;
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
  .prose :global(p) {
    margin-bottom: 1.5em;
    color: #4A4A4A;
    line-height: 1.8;
  }
  .prose :global(a) {
    color: #1A5C3A;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(code) {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.9em;
    background: #F5F3EF;
    padding: 2px 6px;
    border-radius: 4px;
  }
  .prose :global(pre) {
    background: #1A1A1A;
    color: #E8ECF1;
    padding: 1.5em;
    border-radius: 8px;
    overflow-x: auto;
    margin: 2em 0;
    font-size: 14px;
    line-height: 1.6;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }
  .prose :global(blockquote) {
    border-left: 3px solid #1A5C3A;
    padding-left: 1.25em;
    margin: 2em 0;
    font-style: italic;
    color: #7A7A7A;
  }
  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
    color: #4A4A4A;
  }
  .prose :global(li) {
    margin-bottom: 0.5em;
    line-height: 1.7;
  }
  .prose :global(img) {
    border-radius: 8px;
    margin: 2em 0;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid #E8E4DD;
    margin: 3em 0;
  }
</style>
